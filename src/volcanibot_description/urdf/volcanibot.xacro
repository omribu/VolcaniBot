  <!-- LEFT REALSENSE CAMERA -->
  <!-- <link name="camera_left_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://volcanibot_description/meshes/d435.dae"/>
      </geometry>
      <material name="aluminum"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.025 0.090 0.025"/></geometry>
    </collision>
  </link>
  <joint name="camera_left_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_left_link"/>
    <origin xyz="0.58 1.1 -0.135" rpy="0 0.75 0.45"/>
  </joint> -->

  <!-- RIGHT REALSENSE CAMERA -->
  <!-- <link name="camera_right_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://volcanibot_description/meshes/d435.dae"/>
      </geometry>
      <material name="aluminum"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.025 0.090 0.025"/></geometry>
    </collision>
  </link>
  <joint name="camera_right_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_right_link"/>
    <origin xyz="0.58 -1.1 -0.135" rpy="0 0.75 -0.45"/>
  </joint> -->

  <!-- REAR REALSENSE CAMERA -->
  <link name="rear_camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://volcanibot_description/meshes/d435.dae"/>
      </geometry>
      <material name="aluminum"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.025 0.090 0.025"/></geometry>
    </collision>
  </link>
  <joint name="rear_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rear_camera_link"/>
    <origin xyz="-0.686 0.0 -0.15" rpy="0 0 3.14159"/>
  </joint>


  <!-- ROS2_CONTROL — Isaac Sim-->
  <xacro:if value="$(arg use_sim)">
    <ros2_control name="IsaacSimDriveSystem" type="system">
      <hardware>
        <plugin>topic_based_ros2_control/TopicBasedSystem</plugin>
        <param name="joint_states_topic">/joint_states</param>
        <param name="joint_commands_topic">/drive_command</param>
      </hardware>
      <joint name="front_left_wheel_joint">
        <command_interface name="velocity">
          <param name="min">-1</param>
          <param name="max">1</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="front_right_wheel_joint">
        <command_interface name="velocity">
          <param name="min">-1</param>
          <param name="max">1</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="rear_left_wheel_joint">
        <command_interface name="velocity">
          <param name="min">-1</param>
          <param name="max">1</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="rear_right_wheel_joint">
        <command_interface name="velocity">
          <param name="min">-1</param>
          <param name="max">1</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
    </ros2_control>
  </xacro:if>

  <!-- ROS2_CONTROL — Real Hardware -->
  <xacro:unless value="$(arg use_sim)">
    <xacro:include filename="$(find volcanibot_diff_controller)/description/ros2_control/diffbot.ros2_control.xacro"/>
    <xacro:volcanibot_diff_controller name="AgribotDriveSystem" prefix=""/>
  </xacro:unless>

</robot>